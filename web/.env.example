# Pointing at localhost:8080 is OK: when you open the Vite dev app (default :3100), the app rewrites API/WS
# to the same origin so /api and /ws go through the Vite proxy (no CORS, WebSocket Origin matches).
VITE_API_BASE_URL=http://127.0.0.1:8080/api/v1
VITE_WS_BASE_URL=ws://127.0.0.1:8080/ws
VITE_APP_ORIGIN=http://127.0.0.1:8080
# Real backend is the default. Set only for offline demos: OPEN_KRAKEN_API_MODE=mock (see web/src/api/create-client.ts).
# Optional: prefill login (matches backend dev seed owner_1 / admin when unset in dev server)
# VITE_OPEN_KRAKEN_LOGIN_PREFILL_MEMBER_ID=owner_1
# VITE_OPEN_KRAKEN_LOGIN_PREFILL_PASSWORD=admin
