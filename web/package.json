{
  "name": "@open-kraken/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node ./scripts/build.mjs",
    "test": "npm run test:web:unit --",
    "test:ui:members": "npm run build && node ./scripts/members-ui-regression.mjs",
    "test:web:routes": "tsx --test ./src/test/app-shell-routes.test.ts ./src/test/migration-web.test.tsx",
    "test:web:unit": "tsx --test ./src/test/*.test.mjs ./src/test/*.test.ts ./src/test/*.test.tsx",
    "lint": "npm run typecheck",
    "typecheck": "tsc -p ./tsconfig.json --noEmit"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "vite": "^6.3.5",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "esbuild": "^0.25.11",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
