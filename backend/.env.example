OPEN_KRAKEN_HTTP_ADDR=127.0.0.1:8080
OPEN_KRAKEN_API_BASE_PATH=/api/v1
OPEN_KRAKEN_WS_PATH=/ws
OPEN_KRAKEN_APP_DATA_ROOT=./.open-kraken-data
OPEN_KRAKEN_LOG_LEVEL=info
OPEN_KRAKEN_WEB_DIST_DIR=./web/dist

# JWT authentication (leave empty to disable in development).
# Generate with: openssl rand -hex 32
OPEN_KRAKEN_JWT_SECRET=

# Per-IP rate limit (requests/second). 0 = disabled.
OPEN_KRAKEN_RATE_LIMIT_RPS=100

# WebSocket origin policy.
OPEN_KRAKEN_WS_ALLOW_ANY_ORIGIN=true
OPEN_KRAKEN_WS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
